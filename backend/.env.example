# ============================================================
# ASISTENTE PEDAGÓGICO IA - Variables de entorno
# Copia este archivo como .env y completa los valores
# cp .env.example .env
# ============================================================

# ------------------------------------------------------------
# BASE DE DATOS
# Railway: copia la URL de tu PostgreSQL desde el dashboard
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_db
# ------------------------------------------------------------
DATABASE_URL=postgresql://postgres:password@localhost:5432/asistente_pedagogico

# ------------------------------------------------------------
# JWT - Seguridad de tokens
# Genera una clave segura con: python -c "import secrets; print(secrets.token_hex(32))"
# ------------------------------------------------------------
SECRET_KEY=CAMBIA_ESTO_POR_UNA_CLAVE_SECRETA_MUY_LARGA
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ------------------------------------------------------------
# CLAUDE API KEY  ← COLOCA TU CLAVE AQUÍ
# Obtén tu clave en: https://console.anthropic.com/
# Formato: sk-ant-api03-...
# ------------------------------------------------------------
CLAUDE_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Modelo de Claude a usar
CLAUDE_MODEL=claude-opus-4-5

# ------------------------------------------------------------
# STRIPE - Pagos (puedes dejarlo vacío mientras desarrollas)
# Obtén tus claves en: https://dashboard.stripe.com/apikeys
# ------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXX
STRIPE_PRICE_ID_PRO=price_XXXXXXXXXXXXXXXXXX

# ------------------------------------------------------------
# CORS - URL del frontend
# En desarrollo: http://localhost:8080 o http://127.0.0.1:5500
# En producción: https://tu-dominio.com
# ------------------------------------------------------------
FRONTEND_URL=http://localhost:8080

# ------------------------------------------------------------
# ARCHIVOS SUBIDOS
# ------------------------------------------------------------
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# ------------------------------------------------------------
# ENTORNO
# ------------------------------------------------------------
ENVIRONMENT=development
